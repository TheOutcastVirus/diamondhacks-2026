DATABASE_URL=sqlite:///./backend/data/app.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Browser Use Cloud
BROWSER_USE_API_KEY=
BROWSER_USE_MODEL=bu-mini
BROWSER_USE_PROFILE_ID=
BROWSER_USE_PROXY_COUNTRY_CODE=us
BROWSER_USE_MAX_COST_USD=0.50
BROWSER_USE_KEEP_ALIVE=true
BROWSER_USE_IDLE_STOP_SECONDS=90

# Set to false to hard-fail when Browser Use is not configured.
BROWSER_USE_MOCK_MODE=true
