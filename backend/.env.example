APP_NAME=Gazabot Backend
HOST=127.0.0.1
PORT=8000
DATABASE_PATH=./data/gazabot.sqlite
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Browser Use
# Browser automation runs headless/managed in Browser Use Cloud.
# The live session is embedded as an iframe in the Guardian console via previewUrl.
BROWSER_USE_API_KEY=
BROWSER_USE_BASE_URL=https://api.browser-use.com/api/v3
BROWSER_USE_PROFILE_ID=
BROWSER_USE_MODEL=bu-max
BROWSER_USE_KEEP_ALIVE=true
BROWSER_USE_IDLE_STOP_SECONDS=900
BROWSER_USE_POLL_INTERVAL_MS=2000
BROWSER_USE_MAX_POLL_ATTEMPTS=120
# Path to auth_state.json exported by agents/auth/setup_auth.py.
# When set, cookies are injected into every Browser Use session so the agent
# starts pre-authenticated for DoorDash, Grubhub, Uber Eats, Google, etc.
# BROWSER_USE_AUTH_STATE_PATH=/Users/you/gazabot/agents/auth/auth_state.json

# Live embed display options (applied as query params to the iframe URL)
# BROWSER_USE_LIVE_THEME=dark   # "dark" or "light" — omit to use Browser Use default
# BROWSER_USE_LIVE_UI=false     # "false" hides browser chrome in the embed; omit to use default

AGENT_CHUNK_DELAY_MS=140

# Local wake-word subprocess (bot/wake_word.py needs Python venv + bot/requirements.txt).
# Set false if you do not use openWakeWord/pyaudio yet — avoids restart spam in logs.
WAKE_WORD_ENABLED=true

# AssemblyAI (STT)
ASSEMBLY_API_KEY=

# ElevenLabs (TTS)
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
